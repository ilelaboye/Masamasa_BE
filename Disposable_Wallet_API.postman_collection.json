              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"rphDBJvmDAesN38rpgYMUh1UeQ8y9cKfGt:44045\",\n  \"network\": \"RIPPLE\",\n  \"destinationTag\": 44045\n}"
