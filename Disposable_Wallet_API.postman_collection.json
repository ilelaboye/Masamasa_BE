              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"0x22f1B00e4abf7d93BE6d0559C07A1A25a412BAA5\",\n  \"network\": \"BASE\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/web3/disposable/check",
              "host": ["{{base_url}}"],
              "path": ["web3", "disposable", "check"]
            },
            "description": "Check the balance, status, and expiration of a disposable wallet"
          },
          "response": []
        },
