        {
          "name": "Combined Filters",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/web3/disposable/list?status=funded&network=SOLANA&limit=10",
              "host": ["{{base_url}}"],
              "path": ["web3", "disposable", "list"],
              "query": [
                {
                  "key": "status",
                  "value": "funded"
                },
                {
                  "key": "network",
                  "value": "SOLANA"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Combine multiple filters (status + network + pagination)"
          },
          "response": []
        }
      ],
      "description": "List and filter disposable wallets with various criteria"
    },
