        {
          "name": "List with Pagination",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/web3/disposable/list?limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["web3", "disposable", "list"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Paginate through disposable wallets"
          },
          "response": []
