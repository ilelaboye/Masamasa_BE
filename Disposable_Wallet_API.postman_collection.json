    {
      "name": "3. Sweep Wallets",
      "item": [
        {
          "name": "Sweep Single Wallet",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"0x22f1B00e4abf7d93BE6d0559C07A1A25a412BAA5\",\n  \"network\": \"BASE\",\n  \"tokenSymbol\": \"USDT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/web3/disposable/sweep",
              "host": ["{{base_url}}"],
              "path": ["web3", "disposable", "sweep"]
            },
            "description": "Manually sweep funds from a specific disposable wallet to master wallet"
          },
          "response": []
        },
        {
          "name": "Sweep All Funded Wallets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/web3/disposable/sweep-all",
              "host": ["{{base_url}}"],
              "path": ["web3", "disposable", "sweep-all"]
            },
            "description": "Sweep all funded disposable wallets (auto-consolidation)"
          },
          "response": []
        },
        {
          "name": "Sweep All by Network",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/web3/disposable/sweep-all?network=BASE",
              "host": ["{{base_url}}"],
              "path": ["web3", "disposable", "sweep-all"],
              "query": [
                {
                  "key": "network",
                  "value": "BASE"
                }
              ]
            },
            "description": "Sweep all funded wallets on a specific network"
          },
          "response": []
        },
        {
          "name": "Sweep Specific Address",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/web3/disposable/sweep-all?address=0x22f1B00e4abf7d93BE6d0559C07A1A25a412BAA5&network=BASE",
              "host": ["{{base_url}}"],
              "path": ["web3", "disposable", "sweep-all"],
              "query": [
                {
                  "key": "address",
                  "value": "0x22f1B00e4abf7d93BE6d0559C07A1A25a412BAA5"
                },
                {
                  "key": "network",
                  "value": "BASE"
                }
              ]
            },
            "description": "Sweep a specific wallet address"
          },
          "response": []
        }
      ],
      "description": "Sweep (transfer) funds from disposable wallets to master wallet"
    },
