{
  "info": {
    "name": "Disposable Wallet API",
    "description": "Complete collection for managing disposable/temporary wallets across multiple blockchain networks",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "12345678"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "value",
        "value": "{{auth_token}}",
        "type": "string"
      },
      {
        "key": "key",
        "value": "Cookie",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "your_auth_cookie_here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Create Disposable Wallet",
      "item": [
        {
          "name": "Create BASE Wallet (60 min expiry)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"network\": \"BASE\",\n  \"expirationMinutes\": 60,\n  \"expectedAmount\": 100,\n  \"tokenSymbol\": \"USDT\",\n  \"metadata\": {\n    \"purpose\": \"payment\",\n    \"orderId\": \"ORDER-123\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/web3/disposable/create",
              "host": ["{{base_url}}"],
              "path": ["web3", "disposable", "create"]
            },
            "description": "Creates a disposable wallet on BASE network with 60 minutes expiration"
          },
          "response": []
        },
